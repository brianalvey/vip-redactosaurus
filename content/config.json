{
  "settings": {
    "processInterval": 100,
    "maxRetries": 0,
    "debug": false,
    "showDemoIndicator": false,
    "headlineMode": "replace"
  },
  "urlPatterns": {
    "parsely": {
      "pattern": "https://dash\\.parsely\\.com/([^/?]+)",
      "customerIdGroup": 1
    },
    "hosting-dashboard": {
      "pattern": "dashboard\\.wpvip\\.com/apps/([^/?]+)",
      "customerIdGroup": 1
    }
  },
  "transformations": [
    {
      "name": "headlines_replace",
      "type": "functionReplace",
      "enabled": true,
      "enabledSetting": "headlineMode",
      "enabledValue": "replace",
      "selectors": [
        "a.post-title",
        "a[href*='/campaigns/id/']"
      ],
      "options": {
        "functionName": "generateRandomHeadline",
        "functionArgs": {}
      }
    },
    {
      "name": "headlines_scramble",
      "type": "scramble",
      "enabled": true,
      "enabledSetting": "headlineMode",
      "enabledValue": "scramble",
      "selectors": [
        "a.post-title",
        "a[href*='/campaigns/id/']"
      ],
      "options": {
        "preserveCase": true,
        "preservePunctuation": true,
        "preserveSpaces": true,
        "preserveLength": true,
        "preserveEnds": true,
        "maxWordLength": 0
      }
    },
    {
      "name": "author_names",
      "type": "functionReplace",
      "selectors": [
        "div.author a[href*='/authors/']",
        "a[href*='/authors/']"
      ],
      "options": {
        "functionName": "generateRandomAuthorName",
        "functionArgs": {
          "firstNames": [
            "Aisha", "Benjamin", "Carmen", "Dmitri", "Elena", "Finn", "Grace", "Hassan", "Isabella", "Jin", "Kenji", "Lucia", "Miguel", "Nora", "Omar", "Priya", "Quinn", "Raj", "Sofia", "Tomoko", "Ulrich", "Veronica", "Wei", "Ximena", "Yuki", "Zara", "Adrian", "Beatrice", "Carlos", "Diana", "Ethan", "Fatima", "Gabriel", "Hana", "Ivan", "Jasmine", "Klaus", "Leila", "Marco", "Natasha", "Oscar", "Petra", "Quincy", "Rosa", "Sebastian", "Tara", "Uri", "Victoria", "Wolfgang", "Xander", "Yvette", "Zachary"
          ],
          "lastNames": [
            "Anderson", "Blackwood", "Chen", "Delacroix", "Eriksson", "Fernandez", "Gonzalez", "Hoffman", "Ivanov", "Jackson", "Kim", "Lopez", "Murphy", "Nakamura", "O'Brien", "Patel", "Quinn", "Rodriguez", "Singh", "Thompson", "Ueda", "Volkov", "Williams", "Xu", "Yamamoto", "Ziegler", "Abramovich", "Brennan", "Castillo", "Davies", "Fischer", "Hashimoto", "Ibrahim", "Jensen", "Kowalski", "Laurent", "Nielsen", "Okafor", "Petrov", "Qureshi", "Rossi", "Swanson", "Taylor", "Underwood", "Varga", "Walsh", "Xiang", "Yoshida", "Zimmerman"
          ]
        }
      }
    },
    {
      "name": "section_names",
      "type": "functionReplace",
      "selectors": [
        "div.section a[href*='/sections/']",
        "a[href*='/sections/']"
      ],
      "options": {
        "functionName": "generateRandomSectionName",
        "functionArgs": {}
      }
    },
    {
      "name": "article_images",
      "type": "blur",
      "selectors": [
        "div.thumb img"
      ],
      "options": {
        "blurAmount": "3px"
      }
    },
    {
      "name": "publisher_name",
      "type": "functionReplace",
      "selectors": [
        "a.publisher-link span.publisher-info"
      ],
      "options": {
        "functionName": "generatePublisherName",
        "functionArgs": {},
        "preserveChildren": true
      }
    },
    {
      "name": "seo_scramble",
      "type": "scramble",
      "selectors": [
        "div.google-key-label"
      ],
      "options": {
        "preserveCase": true,
        "preservePunctuation": true,
        "preserveSpaces": true,
        "preserveLength": true,
        "preserveEnds": true
      }
    }
  ],
  "globalCSS": {
    "enabled": true,
    "rules": [
      {
        "selector": "div.sitepicker div input.filter",
        "properties": {
          "color": "rgba(255, 0, 0, 0) !important"
        }
      }
    ],
    "files": [
      "assets/global.css"
    ]
  }
}
